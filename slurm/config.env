# =====================================================================
# Anvil configuration — sourced by every sbatch script and go.sh.
# Matches the coauthor's known-good QPINN setup (anaconda module +
# conda env, shared partition, account chm260071).
# =====================================================================

# ACCESS allocation account (award: chm260071).
export QLNN_ACCOUNT="chm260071"

# Conda environment name. The coauthor's env for this project is
# "qlnn" (created by env_setup.sh if missing).
export QLNN_CONDA_ENV="qlnn"

# Repo root on Anvil scratch. env_setup.sh clones here.
export QLNN_ROOT="/anvil/scratch/${USER}/qlnn"

# Partitions. Everything runs on "shared" — the coauthor's QPINN jobs
# run there and it packs sub-node array tasks efficiently.
export QLNN_PARTITION="shared"
export QLNN_DEBUG_PARTITION="shared"

# Thread pinning + XLA compile mitigations applied inside every task.
#
#   NOTE (2026-07-16): --xla_cpu_use_thunk_runtime is REMOVED — Anvil's
#   JAX prints "'xla_cpu_use_thunk_runtime' is no longer supported" and
#   ignores it (observed job 19300125). The kuramoto compile blowup is
#   fixed AT THE SOURCE instead: multi_state_solver now vmaps the
#   per-component circuits (traced graph shrank 11×, 154K → 14K eqns
#   for te_qpinn_qnn × kuramoto; numerically bit-identical).
#
#   JAX_COMPILATION_CACHE_DIR
#       Persistent compile cache on scratch. Cells of the same circuit
#       family share identical HLO across seeds → the first cell pays
#       the compile, requeues and later seeds reuse it.
#
export QLNN_TASK_ENV='export JAX_PLATFORMS=cpu OMP_NUM_THREADS=2 MKL_NUM_THREADS=2 XLA_FLAGS="--xla_force_host_platform_device_count=1" PYTHONUNBUFFERED=1 JAX_COMPILATION_CACHE_DIR="${QLNN_ROOT}/.jax_cache" JAX_PERSISTENT_CACHE_MIN_COMPILE_TIME_SECS=60'
