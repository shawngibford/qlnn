# =====================================================================
# Anvil configuration — EDIT THIS FILE after the ACCESS award lands.
# Every sbatch script and submit_all.sh sources this file.
# =====================================================================

# ACCESS allocation account string (from the award email, e.g. "cis250123").
export QLNN_ACCOUNT="CHANGE_ME"

# Repo root on Anvil scratch. env_setup.sh clones here.
export QLNN_ROOT="/anvil/scratch/${USER}/qlnn"

# Virtualenv path (built by env_setup.sh).
export QLNN_VENV="${QLNN_ROOT}/.venv"

# Partitions: Anvil CPU. "shared" packs sub-node array tasks; "debug"
# for the smoke pass (max 2 nodes / 2 hr).
export QLNN_PARTITION="shared"
export QLNN_DEBUG_PARTITION="debug"

# Thread pinning applied inside every task. 2 cores per task; stop
# XLA/OpenMP from grabbing the whole node.
export QLNN_TASK_ENV='export JAX_PLATFORMS=cpu OMP_NUM_THREADS=2 MKL_NUM_THREADS=2 XLA_FLAGS="--xla_force_host_platform_device_count=1" PYTHONUNBUFFERED=1'
