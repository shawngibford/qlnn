# =====================================================================
# Anvil configuration — sourced by every sbatch script and go.sh.
# Matches the coauthor's known-good QPINN setup (anaconda module +
# conda env, shared partition, account chm260071).
# =====================================================================

# ACCESS allocation account (award: chm260071).
export QLNN_ACCOUNT="chm260071"

# Conda environment name. The coauthor's env for this project is
# "qlnn" (created by env_setup.sh if missing).
export QLNN_CONDA_ENV="qlnn"

# Repo root on Anvil scratch. env_setup.sh clones here.
export QLNN_ROOT="/anvil/scratch/${USER}/qlnn"

# Partitions. Everything runs on "shared" — the coauthor's QPINN jobs
# run there and it packs sub-node array tasks efficiently.
export QLNN_PARTITION="shared"
export QLNN_DEBUG_PARTITION="shared"

# Thread pinning applied inside every task. 2 cores per task; stop
# XLA/OpenMP from grabbing the whole node.
export QLNN_TASK_ENV='export JAX_PLATFORMS=cpu OMP_NUM_THREADS=2 MKL_NUM_THREADS=2 XLA_FLAGS="--xla_force_host_platform_device_count=1" PYTHONUNBUFFERED=1'
